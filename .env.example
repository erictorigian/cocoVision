RTSP_URL=rtsp://admin:cocoTracker@10.27.27.19:10554/tcp/av0_0

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://wkxedsjdkkczreprjsvc.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Docker networking ─────────────────────────────────────────────────────────
# Name of your existing shared homelab Docker network
HOMELAB_NETWORK=homelab

# ── Detection tuning (all optional — defaults shown) ─────────────────────────
WORKING_WIDTH=640
WORKING_HEIGHT=360
TARGET_FPS=3
DEBOUNCE_SECONDS=3
SLEEP_THRESHOLD_SECONDS=300
MOTION_THRESHOLD=500

# ── Clip settings ─────────────────────────────────────────────────────────────
CLIPS_MAX=50
CLIP_PRE_SECONDS=5
CLIP_POST_SECONDS=10

# ── Wake-up notification (Home Assistant REST API) ────────────────────────────
# Leave blank to disable. Fill in when HA is ready.
# Example: http://homeassistant.local:8123/api/services/tts/speak
# The detector POSTs {"event":"coco_active","timestamp":"..."} to this URL.
WAKEUP_WEBHOOK_URL=
NOTIFICATION_COOLDOWN=300
